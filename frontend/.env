# Expo public env — EXPO_PUBLIC_* values are inlined into the client bundle.
# Do NOT put real secrets here (no API keys / server secrets); they end up shipped
# in the app. After editing, restart Metro with a clear cache: `expo start -c`.

# --- Backend ---
# Android emulator: use http://10.0.2.2:5000 ; physical device: your machine's LAN IP.
EXPO_PUBLIC_API_URL=http://localhost:5000/api
EXPO_PUBLIC_SOCKET_URL=http://localhost:5000

# --- WebRTC ICE / TURN ---
# Preferred: fetch ICE at call time from the backend (GET /api/calls/ice-servers),
# which resolves Metered credentials server-side and keeps the API key off the client.
# The values below are Metered's STATIC relay credentials (client-safe by design),
# usable as a quick-start / offline fallback.
EXPO_PUBLIC_STUN_URL=stun:stun.relay.metered.ca:80
EXPO_PUBLIC_TURN_URLS=turn:global.relay.metered.ca:80,turn:global.relay.metered.ca:80?transport=tcp,turn:global.relay.metered.ca:443,turns:global.relay.metered.ca:443?transport=tcp
EXPO_PUBLIC_TURN_USERNAME=e9ba09d931def9704f68ae37
EXPO_PUBLIC_TURN_CREDENTIAL=h8J8NGEJYB0hXwHZ
