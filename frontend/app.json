{
  "expo": {
    "name": "Chatloop",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.chatloop.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      "expo-notifications",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Chatloop uses your camera for video calls.",
          "microphonePermission": "Chatloop uses your microphone for voice and video calls."
        }
      ],
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "Chatloop accesses your photos so you can share them as a status.",
          "cameraPermission": "Chatloop uses your camera to capture a status photo or video.",
          "microphonePermission": "Chatloop uses your microphone to record a status video."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
