# Leave VITE_API_BASE_URL empty to use the Vite dev proxy (same-origin /api ->
# the target below). This avoids any CORS configuration during local dev.
VITE_API_BASE_URL=

# Where the Vite dev proxy forwards /api requests (your running backend).
VITE_PROXY_TARGET=http://localhost:5000

# To call a deployed backend directly (no proxy), set the full origin instead and
# make sure the backend's CORS_ORIGIN allows this dashboard's URL:
# VITE_API_BASE_URL=https://api.yourdomain.com
