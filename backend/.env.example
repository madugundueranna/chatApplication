# Server
NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/chatApplication

# Redis (single shared instance — cache, socket adapter, rate-limit, queues)
# Local Redis uses redis://. Cloud Redis that requires TLS (e.g. Upstash) MUST use rediss://
REDIS_URL=redis://127.0.0.1:6379

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_REFRESH_EXPIRES=7d

# Auth
BCRYPT_ROUNDS=10
OTP_TTL_MINUTES=10

# Admin dashboard — the account with this email is auto-promoted to admin on
# startup (so it can sign into /api/admin/*). Register the user first, set this,
# then restart. Leave blank to disable auto-promotion.
ADMIN_EMAIL=

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="Chat App <no-reply@chat.app>"

# Push notifications (Expo). Device pushes are sent through Expo's push service;
# no key is required for basic sending. Set an access token only if you've enabled
# "Enhanced Security for Push Notifications" in your Expo account.
EXPO_ACCESS_TOKEN=

# Media storage (Cloudinary). Required for file/image messages, status media and
# avatar uploads — buffers are streamed to Cloudinary; the API stores the URL.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# WebRTC calling — signaling + ICE config (media is peer-to-peer, never via the server)
# Ring window before an unanswered call is marked missed, and per-user initiate throttle.
CALL_RING_TIMEOUT_MS=35000
CALL_INITIATE_THROTTLE_SECONDS=3

# TURN is REQUIRED for calls to connect across most NATs/firewalls.
# The backend hands clients ICE config via GET /api/calls/ice-servers (or the
# call:ice-servers socket event) — secrets are resolved server-side and never
# embedded in the client.

# --- Option A (recommended): managed TURN via Metered ---
# The server fetches account ICE servers from Metered's REST API; the API key
# stays server-side. Find both under your Metered dashboard.
METERED_DOMAIN=your-subdomain.metered.live
METERED_API_KEY=your_metered_api_key
# How long to cache the fetched ICE config (seconds); keep well under cred validity.
METERED_CACHE_TTL_SECONDS=600

# --- Option B: self-hosted coturn / generic TURN (used only if Metered is unset) ---
# Comma-separated URLs, e.g. turn:turn.example.com:3478,turns:turn.example.com:5349
TURN_URLS=
# Short-lived credentials via the coturn TURN REST API shared secret
# (coturn `use-auth-secret` / `static-auth-secret`). The secret never leaves the server.
TURN_STATIC_AUTH_SECRET=
TURN_CRED_TTL_SECONDS=86400
# Fallback only: static long-term TURN credentials (used when no shared secret is set).
TURN_USERNAME=
TURN_PASSWORD=
# STUN: comma-separated. Defaults to Google STUN if unset.
STUN_URLS=stun:stun.l.google.com:19302
